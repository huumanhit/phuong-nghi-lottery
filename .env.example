# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lottery_db"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Public base URL (used by cron job to call internal APIs)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Cron job protection secret — set the same value when calling the endpoint
# GET /api/cron/check-tickets?secret=your-cron-secret
CRON_SECRET="your-cron-secret-here"
