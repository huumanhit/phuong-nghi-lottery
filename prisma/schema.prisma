generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  tickets   LotteryTicket[]
}

model LotteryTicket {
  id           String   @id @default(uuid())
  userId       String
  province     String
  drawDate     DateTime
  ticketNumber String
  status       TicketStatus @default(pending)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([ticketNumber])
  @@index([drawDate])
  @@index([province])
}

enum TicketStatus {
  pending
  win
  lose
}

model LotteryResult {
  id           String   @id @default(uuid())
  date         DateTime
  region       String
  province     String
  prize8       String?
  prize7       String?
  prize6       String?
  prize5       String?
  prize4       String?
  prize3       String?
  prize2       String?
  prize1       String?
  specialPrize String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([region])
  @@index([province])
}

model LotterySchedule {
  id        String   @id @default(uuid())
  weekday   Int
  region    String
  province  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  referrer  String   @default("")
  userAgent String   @default("")
  ip        String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

model StoreInfo {
  id          String   @id @default("main")
  storeName   String   @default("")
  tagline     String   @default("")
  description String   @default("")
  address1    String   @default("")
  address2    String   @default("")
  phone       String   @default("")
  email       String   @default("")
  openHours   String   @default("")
  mapEmbedUrl String   @default("")
  logoUrl        String   @default("")
  headerSettings String   @default("")
  updatedAt      DateTime @updatedAt
}

model LandingSection {
  id        String   @id @default(uuid())
  title     String   @default("")
  content   String   @default("")
  imageUrl  String   @default("")
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model DealerPoint {
  id        String   @id @default(uuid())
  city      String   @default("TP. Hồ Chí Minh")
  pointType String   @default("Điểm hợp tác")
  name      String   @default("")
  phone     String   @default("")
  address   String   @default("")
  mapUrl    String   @default("")
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@index([pointType])
}

model NewsItem {
  id        String   @id @default(uuid())
  title     String   @default("")
  imageUrl  String   @default("")
  linkUrl   String   @default("")
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model Article {
  id          String   @id @default(uuid())
  category    String   @default("tin-tuc")
  title       String   @default("")
  excerpt     String   @default("")
  content     String   @default("")
  imageUrl    String   @default("")
  publishedAt DateTime @default(now())
  sortOrder   Int      @default(0)
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([publishedAt])
  @@index([sortOrder])
}

model GalleryImage {
  id          String   @id @default(uuid())
  title       String   @default("")
  description String   @default("")
  imageUrl    String   @default("")
  sortOrder   Int      @default(0)
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

model VideoItem {
  id           String   @id @default(uuid())
  title        String   @default("")
  description  String   @default("")
  youtubeUrl   String   @default("")
  thumbnailUrl String   @default("")
  sortOrder    Int      @default(0)
  visible      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sortOrder])
}

model JobPosting {
  id           String   @id @default(uuid())
  title        String   @default("")
  description  String   @default("")
  requirements String   @default("")
  salary       String   @default("")
  location     String   @default("")
  contactName  String   @default("")
  contactPhone String   @default("")
  sortOrder    Int      @default(0)
  visible      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sortOrder])
}